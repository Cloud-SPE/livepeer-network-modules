# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Local env / secrets
.env
.env.local
*.pem
*.key

# Build output (when code arrives)
/dist/
/build/
/out/
/bin/
/protocol-daemon/bin/
# Per-workspace build outputs (gateways, customer-portal, etc.)
**/dist/

# Compiled Go binaries (built into runner Docker images, not checked in)
/video-runners/transcode-runner/transcode-runner
/video-runners/abr-runner/abr-runner

# Coverage artifacts
coverage.out
cov.out
*.coverprofile

# Node / pnpm
node_modules/
**/node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TS test-build outputs (e.g. daydream-gateway's `pnpm test` writes here)
**/dist-test/
**/*.tsbuildinfo

# Generated docs (keep checked-in artifacts as sources of truth; output is regen-able)
/docs/generated/*
!/docs/generated/.gitkeep

# Python caches / local locks from auxiliary components
__pycache__/
*.pyc
/vtuber-pipeline/uv.lock
/vtuber-runner/uv.lock
