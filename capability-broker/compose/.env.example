REGISTRY=tztcloud
TAG=v1.0.0

BROKER_LOG_LEVEL=info
BROKER_LISTEN_PORT=8080
BROKER_METRICS_PORT=9090
BROKER_RTMP_PORT=1935
BROKER_ENCODER=auto

# Module-local host-config path mounted into the container.
BROKER_CONFIG=./host-config.yaml

# Directory containing payment-daemon.sock on the host or from a sibling
# container/volume mount.
PAYMENT_DAEMON_SOCKET_DIR=/var/run/livepeer
