{
  "name": "@livepeer-network-modules/customer-portal-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared light-DOM widget catalog for the customer portal frontend",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./controllers/*": {
      "types": "./dist/controllers/*.d.ts",
      "import": "./dist/controllers/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./css/*": "./dist/css/*"
  },
  "scripts": {
    "build": "tsc && node ./scripts/build-css.mjs",
    "test": "tsc -p tsconfig.test.json && node --test ./dist-test/test/**/*.test.js"
  },
  "dependencies": {
    "lit": "^3.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
