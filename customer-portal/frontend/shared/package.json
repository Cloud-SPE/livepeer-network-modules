{
  "name": "@livepeer-rewrite/customer-portal-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Lit + RxJS widget catalog for the customer portal frontend",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./controllers/*": {
      "types": "./dist/controllers/*.d.ts",
      "import": "./dist/controllers/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./css/*": "./src/css/*"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc -p tsconfig.test.json && node --test ./dist-test/test/**/*.test.js"
  },
  "dependencies": {
    "lit": "^3.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jsdom": "^25.0.0",
    "@types/jsdom": "^21.1.7",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
