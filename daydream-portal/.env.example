# Copy to .env (gitignored) before running `pnpm start`.

# Bind address — change to 0.0.0.0 for container, 127.0.0.1 for host-only.
DAYDREAM_PORTAL_LISTEN_HOST=127.0.0.1
DAYDREAM_PORTAL_LISTEN_PORT=8080

# Postgres DSN. compose.yaml exposes the local Postgres on host port
# 55432; the in-container port stays at 5432.
DAYDREAM_PORTAL_POSTGRES_URL=postgres://daydream:daydream@127.0.0.1:55432/daydream_portal

# Pepper for API-key hashing. Must be >= 16 chars in prod.
DAYDREAM_PORTAL_AUTH_PEPPER=dev-pepper-please-rotate

# Comma-separated admin tokens. Each admin call sends the token via
# X-Admin-Token + the operator's name via X-Admin-Actor.
DAYDREAM_PORTAL_ADMIN_TOKENS=dev-admin-token

# Base URL of the sibling daydream-gateway. Sessions and gateway probes
# are issued against this host.
DAYDREAM_PORTAL_GATEWAY_BASE_URL=http://127.0.0.1:9100

# Capability advertised by daydream-gateway. Don't change unless the
# gateway is forked to advertise a different name.
DAYDREAM_PORTAL_CAPABILITY=daydream-scope

# UI token TTL, in milliseconds. Default 1 hour.
DAYDREAM_PORTAL_UI_TOKEN_TTL_MS=3600000
