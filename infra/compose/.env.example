# Shared infrastructure compose env. Copy to .env, edit, then:
#   docker compose -f infra/compose/docker-compose.yml --env-file infra/compose/.env --profile pg up -d

# ---- Postgres (profile: pg) ----
POSTGRES_USER=livepeer
POSTGRES_PASSWORD=livepeer
POSTGRES_DB=livepeer
POSTGRES_PORT=5432

# ---- Redis (profile: redis) ----
REDIS_PORT=6379

# ---- RustFS (profile: rustfs) ----
RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=rustfsadmin
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_DEFAULT_BUCKET=transcoded
