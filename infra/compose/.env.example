# Shared infrastructure compose env. Copy to .env, edit, then:
#   docker compose -f infra/compose/docker-compose.yml --env-file infra/compose/.env --profile pg up -d

# ---- Postgres (profile: pg) ----
POSTGRES_USER=livepeer
POSTGRES_PASSWORD=livepeer
POSTGRES_DB=livepeer
POSTGRES_PORT=5432

# ---- Redis (profile: redis) ----
REDIS_PORT=6379

# ---- MinIO (profile: minio) ----
MINIO_ROOT_USER=minio4dmin
MINIO_ROOT_PASSWORD=minio4dmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DEFAULT_BUCKET=transcoded
