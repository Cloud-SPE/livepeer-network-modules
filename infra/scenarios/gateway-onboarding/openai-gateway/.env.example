# OpenAI Gateway — env file.
#
# Copy to .env, fill in your own values, then bring the stack up with:
#   docker compose \
#     -f infra/scenarios/gateway-onboarding/openai-gateway/docker-compose.yml \
#     --env-file infra/scenarios/gateway-onboarding/openai-gateway/.env \
#     up -d

# --- images ---
REGISTRY=tztcloud
TAG=v1.0.0
POSTGRES_TAG=16-alpine

# --- chain wiring ---
# Single RPC endpoint. service-registry-daemon polls this for the
# manifest registry; payment-daemon-sender uses it for ticket payments.
CHAIN_RPC=https://arb1.arbitrum.io/rpc
CHAIN_ID=42161
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4
AI_SERVICE_REGISTRY_ADDRESS=0x04C0b249740175999E5BF5c9ac1dA92431EF34C5

# --- service-registry-daemon tuning ---
DISCOVERY_MODE=chain
ROUND_POLL_INTERVAL=120s
CACHE_MANIFEST_TTL=5m
MANIFEST_MAX_BYTES=1048576
MANIFEST_FETCH_TIMEOUT=5s
MAX_STALE=30m
REJECT_UNSIGNED=true
STATIC_OVERLAY=
REGISTRY_LOG_LEVEL=info
REGISTRY_LOG_FORMAT=json
REGISTRY_METRICS_PORT=9095

# --- gateway hot wallet ---
# Single keystore the gateway uses to sign ticket-payment transactions
# AND to authenticate itself to orchestrators. There is no cold/hot
# split on the gateway side — this key signs everything.
#
# Treat this as a throwaway wallet:
#   - keep funding small (just enough deposit + reserve to keep work
#     flowing through the orchs you talk to)
#   - rotate immediately if compromised — generate a new key, fund it,
#     update the keystore + restart the stack
#   - never reuse this key for anything else
PAYMENT_KEYSTORE=/opt/livepeer/keystore.json
PAYMENT_KEYSTORE_PASSWORD_FILE=/opt/livepeer/keystore-password

# Optional: keystore password as env var instead of a file. Leave blank
# to use the file at PAYMENT_KEYSTORE_PASSWORD_FILE.
LIVEPEER_KEYSTORE_PASSWORD=

# --- database credentials ---
# Used by both the postgres init AND the gateway's DATABASE_URL (built
# automatically in compose). Set once here; compose interpolates into
# both.
#
# POSTGRES_PASSWORD must be URL-safe (alphanumeric recommended). If you
# need special chars, URL-encode them before setting here.
# Generate with: openssl rand -hex 24
POSTGRES_USER=livepeer
POSTGRES_PASSWORD=
POSTGRES_DB=openai_gateway

# --- gateway secrets ---
# Pepper for customer-portal auth tokens. Treat as a secret — rotating
# invalidates all issued portal tokens.
# Generate with: openssl rand -hex 32
CUSTOMER_PORTAL_AUTH_PEPPER=

# Comma-separated admin tokens for the gateway's operator API. Generate
# fresh and rotate on operator handoff.
# Generate with: openssl rand -hex 32
OPENAI_GATEWAY_ADMIN_TOKENS=

# --- gateway runtime tuning ---
# How long the manifest snapshot stays cached before re-resolution.
LIVEPEER_RESOLVER_SNAPSHOT_TTL_MS=15000

# Surface the OpenAI audio-speech endpoint? Set true only if you have at
# least one broker advertising `openai:audio-speech` on your fleet.
OPENAI_AUDIO_SPEECH_ENABLED=false

# Per-request timeout when calling a capability broker.
BROKER_CALL_TIMEOUT_MS=30000

# --- Layer 3 route health (gateway-local circuit breaker) ---
# How many consecutive retryable failures on a single broker route open
# a cooldown for that route. Lower = trip faster on flaky brokers;
# higher = tolerate transient blips. The resolver already pre-filters
# Layer 2 (broker /registry/health) — these knobs control gateway-local
# Layer 3 only. See docs/design-docs/backend-health.md.
LIVEPEER_ROUTE_FAILURE_THRESHOLD=2

# How long a route stays in cooldown after tripping (milliseconds).
LIVEPEER_ROUTE_COOLDOWN_MS=30000

# Gateway log verbosity.
GATEWAY_LOG_LEVEL=info

# --- standalone port (overridden by ingress overlays) ---
# Where the gateway is exposed when no ingress overlay is layered on.
# Production deployments layer one of the ingress overlays and these
# are ignored.
OPENAI_GATEWAY_BIND=0.0.0.0
OPENAI_GATEWAY_PORT=3000

# --- Ingress overlays — public hostname (Traefik / Nginx overlays) ---
# Public hostname your customers reach the gateway at. Used by both the
# Traefik and Nginx overlays for cert issuance and routing.
GATEWAY_HOST=gateway.example.com

# --- Traefik overlay (only used with docker-compose.traefik.yml) ---
# Which Traefik cert resolver to use. Match what's defined in your
# traefik.yml.
TRAEFIK_CERTRESOLVER=cloudflare

# --- Nginx DNS-01 overlay (only used with docker-compose.nginx-dns01.yml) ---
# Leave blank when using HTTP-01 (docker-compose.nginx.yml). Populate to
# issue certs via Cloudflare DNS-01. Token needs Zone:DNS:Edit on the
# zone hosting GATEWAY_HOST.
CF_DNS_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
