# Video Gateway — env file.
#
# Copy to .env, fill in your own values, then bring the stack up with:
#   docker compose \
#     -f infra/scenarios/gateway-onboarding/video-gateway/docker-compose.yml \
#     --env-file infra/scenarios/gateway-onboarding/video-gateway/.env \
#     up -d

# --- images ---
REGISTRY=tztcloud
TAG=v1.0.0
POSTGRES_TAG=16-alpine
REDIS_TAG=7-alpine
RUSTFS_TAG=latest

# --- chain wiring ---
# Single RPC endpoint. service-registry-daemon polls this for the
# manifest registry; payment-daemon-sender uses it for ticket payments.
CHAIN_RPC=https://arb1.arbitrum.io/rpc
CHAIN_ID=42161
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4
AI_SERVICE_REGISTRY_ADDRESS=0x04C0b249740175999E5BF5c9ac1dA92431EF34C5

# --- service-registry-daemon tuning ---
DISCOVERY_MODE=chain
ROUND_POLL_INTERVAL=120s
CACHE_MANIFEST_TTL=5m
MANIFEST_MAX_BYTES=1048576
MANIFEST_FETCH_TIMEOUT=5s
MAX_STALE=30m
REJECT_UNSIGNED=true
STATIC_OVERLAY=
REGISTRY_LOG_LEVEL=info
REGISTRY_LOG_FORMAT=json
REGISTRY_METRICS_PORT=9095

# --- gateway hot wallet ---
# Single keystore the gateway uses to sign ticket-payment transactions
# AND to authenticate itself to capability brokers. There is no cold/hot
# split on the gateway side — this key signs everything.
#
# Treat this as a throwaway hot wallet:
#   - keep funding small (just enough deposit + reserve to keep work
#     flowing through the orchs you talk to)
#   - rotate immediately if compromised — generate a new key, fund it,
#     update the keystore + restart the stack
#   - never reuse this key for anything else
PAYMENT_KEYSTORE=/opt/livepeer/keystore.json
PAYMENT_KEYSTORE_PASSWORD_FILE=/opt/livepeer/keystore-password

# Optional: keystore password as env var instead of a file. Leave blank
# to use the file at PAYMENT_KEYSTORE_PASSWORD_FILE.
LIVEPEER_KEYSTORE_PASSWORD=

# --- database credentials ---
# Used by both the postgres init AND the gateway's DATABASE_URL (built
# automatically in compose). Set once here; compose interpolates into
# both. POSTGRES_PASSWORD must be URL-safe (alphanumeric recommended;
# URL-encode special chars).
# Generate with: openssl rand -hex 24
POSTGRES_USER=livepeer
POSTGRES_PASSWORD=
POSTGRES_DB=video_gateway

# --- redis ---
# Used for live-stream state + the stale-stream sweeper queue. Default
# targets the bundled redis service.
REDIS_URL=redis://redis:6379/0

# --- object storage (S3 / rustfs) ---
# Bundled rustfs is the default for self-contained dev / single-host
# deploys. To use AWS S3 or another provider instead, override
# S3_ENDPOINT, S3_REGION, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY.
#
# Rustfs root credentials (initialize the bundled storage). Used by
# rustfs itself AND, by default, as the S3_* credentials when the
# gateway talks to it.
# Generate with: openssl rand -hex 16  (for each)
RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=

# S3 wiring for the gateway. Defaults to the bundled rustfs. Override
# all four for an external provider.
S3_REGION=us-east-1
S3_BUCKET=transcoded
S3_ENDPOINT=http://rustfs:9000
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# --- gateway secrets ---
# HMAC pepper for webhook signing. Rotating invalidates in-flight
# signed webhooks.
# Generate with: openssl rand -hex 32
VIDEO_WEBHOOK_HMAC_PEPPER=

# Pepper for customer-portal auth tokens. Rotating invalidates all
# issued portal tokens.
# Generate with: openssl rand -hex 32
CUSTOMER_PORTAL_PEPPER=

# Comma-separated admin tokens for the gateway's operator API. Generate
# fresh and rotate on operator handoff.
# Generate with: openssl rand -hex 32
VIDEO_GATEWAY_ADMIN_TOKENS=

# --- gateway runtime tuning ---
LIVEPEER_RESOLVER_SNAPSHOT_TTL_MS=15000
VIDEO_VOD_TUS_PATH=/v1/uploads
VIDEO_GATEWAY_ABR_POLICY=customer-tier
VIDEO_STALE_STREAM_SWEEP_INTERVAL_SECONDS=60
BROKER_CALL_TIMEOUT_MS=30000

# --- Layer 3 route health (gateway-local circuit breaker) ---
# Tunables for the gateway-local circuit breaker. The resolver already
# pre-filters by Layer 2 (broker /registry/health); these knobs control
# Layer 3 only. Uncomment to override the defaults shown.
# See docs/design-docs/backend-health.md.
#
# Consecutive retryable failures on a single broker route before a
# cooldown opens. Lower = trip faster on flaky brokers; higher = tolerate
# transient blips.
#LIVEPEER_ROUTE_FAILURE_THRESHOLD=2
#
# How long a route stays in cooldown after tripping (milliseconds).
#LIVEPEER_ROUTE_COOLDOWN_MS=30000

GATEWAY_LOG_LEVEL=info

# --- standalone ports (HTTP overridden by ingress overlays; RTMP always direct) ---
# Where the gateway's HTTP API is exposed when no ingress overlay is
# layered on. The ingress overlays drop this mapping; the RTMP mapping
# is always kept (RTMP is TCP, can't go through HTTP proxies).
VIDEO_GATEWAY_BIND=0.0.0.0
VIDEO_GATEWAY_PORT=5000

# RTMP ingest port. Standard is 1935; change if your host already has
# another RTMP listener.
VIDEO_RTMP_BIND=0.0.0.0
VIDEO_RTMP_PORT=1935

# --- Ingress overlays — public hostname (Traefik / Nginx overlays) ---
# Public hostname your customers reach the gateway HTTP API at. Used by
# both the Traefik and Nginx overlays for cert issuance and routing.
GATEWAY_HOST=video-gateway.example.com

# --- Traefik overlay (only used with docker-compose.traefik.yml) ---
TRAEFIK_CERTRESOLVER=cloudflare

# --- Nginx DNS-01 overlay (only used with docker-compose.nginx-dns01.yml) ---
# Leave blank when using HTTP-01 (docker-compose.nginx.yml). Populate to
# issue certs via Cloudflare DNS-01. Token needs Zone:DNS:Edit on the
# zone hosting GATEWAY_HOST.
CF_DNS_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
