# Vtuber Gateway — env file. [PREVIEW]
#
# DO NOT USE ON LIVE NETWORK. The vtuber-gateway is under development.
# This file describes the target configuration shape.
#
# Copy to .env, fill in your own values, then bring the stack up with:
#   docker compose \
#     -f infra/scenarios/gateway-onboarding/vtuber-gateway/docker-compose.yml \
#     --env-file infra/scenarios/gateway-onboarding/vtuber-gateway/.env \
#     up -d

# --- images ---
REGISTRY=tztcloud
TAG=v1.0.0
POSTGRES_TAG=16-alpine

# --- chain wiring ---
CHAIN_RPC=https://arb1.arbitrum.io/rpc
CHAIN_ID=42161
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4
AI_SERVICE_REGISTRY_ADDRESS=0x04C0b249740175999E5BF5c9ac1dA92431EF34C5

# --- service-registry-daemon tuning ---
DISCOVERY_MODE=chain
ROUND_POLL_INTERVAL=120s
CACHE_MANIFEST_TTL=5m
MANIFEST_MAX_BYTES=1048576
MANIFEST_FETCH_TIMEOUT=5s
MAX_STALE=30m
REJECT_UNSIGNED=true
STATIC_OVERLAY=
REGISTRY_LOG_LEVEL=info
REGISTRY_LOG_FORMAT=json
REGISTRY_METRICS_PORT=9095

# --- gateway hot wallet ---
# Same throwaway-wallet model as the OpenAI and Video gateways:
# small funding, rotate on compromise, maintain reserve, never reuse.
PAYMENT_KEYSTORE=/opt/livepeer/keystore.json
PAYMENT_KEYSTORE_PASSWORD_FILE=/opt/livepeer/keystore-password
LIVEPEER_KEYSTORE_PASSWORD=

# Default face value for payer-issued tickets. In wei. The gateway will
# choose a face value at or below this for each ticket.
LIVEPEER_PAYER_DEFAULT_FACE_VALUE_WEI=5000000000000000000

# --- database credentials ---
# Used by both the postgres init AND the gateway's DATABASE_URL (built
# automatically in compose). POSTGRES_PASSWORD must be URL-safe
# (alphanumeric is fine; URL-encode special chars).
# Generate with: openssl rand -hex 24
POSTGRES_USER=livepeer
POSTGRES_PASSWORD=
POSTGRES_DB=vtuber_gateway

# --- vtuber-specific secrets ---
# Pepper for vtuber session bearer tokens (issued to customers per
# session). Rotating invalidates active sessions.
# Generate with: openssl rand -hex 32
VTUBER_SESSION_BEARER_PEPPER=

# Pepper for worker control-channel bearer tokens (issued to the broker
# the gateway is currently relaying to).
# Generate with: openssl rand -hex 32
VTUBER_WORKER_CONTROL_BEARER_PEPPER=

# --- vtuber session model ---
# Default offering label requested when a customer opens a session
# without specifying.
VTUBER_DEFAULT_OFFERING=default

# How long a session is allowed to live before forced close, in seconds.
VTUBER_SESSION_DEFAULT_TTL_SECONDS=3600

# Lifetime of the session bearer token, in seconds. Should be ≥ session
# TTL to survive reconnects.
VTUBER_SESSION_BEARER_TTL_SECONDS=7200

# Rate card in USD per second of session time. Pricing model for vtuber
# sessions is per-second; the gateway converts to wei via the chain RPC
# at ticket time.
VTUBER_RATE_CARD_USD_PER_SECOND=0.01

# Per-request timeout when the gateway calls the broker's worker.
VTUBER_WORKER_CALL_TIMEOUT_MS=15000

# Max simultaneous relays (sub-channels) per session.
VTUBER_RELAY_MAX_PER_SESSION=8

# --- vtuber control-channel reconnect ---
# Window for the customer to reconnect a dropped control channel before
# the session is closed.
VTUBER_CONTROL_RECONNECT_WINDOW=30s

# Messages buffered for replay on reconnect.
VTUBER_CONTROL_RECONNECT_BUFFER_MESSAGES=64

# Buffer size cap in bytes.
VTUBER_CONTROL_RECONNECT_BUFFER_BYTES=1048576

# --- gateway runtime tuning ---
LIVEPEER_RESOLVER_SNAPSHOT_TTL_MS=15000

# --- Layer 3 route health (gateway-local circuit breaker) ---
# Tunables for the gateway-local circuit breaker. The resolver already
# pre-filters by Layer 2 (broker /registry/health); these knobs control
# Layer 3 only. Uncomment to override the defaults shown.
# See docs/design-docs/backend-health.md.
#
# Consecutive retryable failures on a single broker route before a
# cooldown opens. Lower = trip faster on flaky brokers; higher = tolerate
# transient blips.
#LIVEPEER_ROUTE_FAILURE_THRESHOLD=2
#
# How long a route stays in cooldown after tripping (milliseconds).
#LIVEPEER_ROUTE_COOLDOWN_MS=30000

GATEWAY_LOG_LEVEL=info

# --- standalone port (overridden by ingress overlays) ---
VTUBER_GATEWAY_BIND=0.0.0.0
VTUBER_GATEWAY_PORT=3001

# --- Ingress overlays — public hostname (Traefik / Nginx overlays) ---
# Public hostname your customers reach the gateway at.
GATEWAY_HOST=vtuber-gateway.example.com

# --- Traefik overlay (only used with docker-compose.traefik.yml) ---
TRAEFIK_CERTRESOLVER=cloudflare

# --- Nginx DNS-01 overlay (only used with docker-compose.nginx-dns01.yml) ---
# Leave blank when using HTTP-01 (docker-compose.nginx.yml). Populate to
# issue certs via Cloudflare DNS-01. Token needs Zone:DNS:Edit on the
# zone hosting GATEWAY_HOST.
CF_DNS_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
