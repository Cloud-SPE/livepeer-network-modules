REGISTRY=tztcloud
TAG=v1.0.0

OPENAI_GATEWAY_BIND=0.0.0.0
OPENAI_GATEWAY_PORT=3000
GATEWAY_LOG_LEVEL=info

CHAIN_RPC=https://arb1.arbitrum.io/rpc
CHAIN_ID=42161
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4
SERVICE_REGISTRY_ADDRESS=0xYOUR_ONCHAIN_SERVICE_REGISTRY
DISCOVERY_MODE=chain
ROUND_POLL_INTERVAL=15s
CACHE_MANIFEST_TTL=5m
MANIFEST_MAX_BYTES=1048576
MANIFEST_FETCH_TIMEOUT=5s
MAX_STALE=30m
REJECT_UNSIGNED=true
STATIC_OVERLAY=
REGISTRY_LOG_LEVEL=info
REGISTRY_LOG_FORMAT=json
REGISTRY_METRICS_PORT=9095

LIVEPEER_DEFAULT_OFFERING=model-small
LIVEPEER_RESOLVER_SNAPSHOT_TTL_MS=15000
BROKER_CALL_TIMEOUT_MS=30000
OPENAI_AUDIO_SPEECH_ENABLED=false

PAYMENT_KEYSTORE=./run/gateway-hot-wallet-keystore.json
PAYMENT_KEYSTORE_PASSWORD_FILE=./run/keystore-password
LIVEPEER_KEYSTORE_PASSWORD=

POSTGRES_USER=livepeer
POSTGRES_PASSWORD=livepeer
POSTGRES_DB=openai_gateway
POSTGRES_PORT=5432
DATABASE_URL=postgres://livepeer:livepeer@postgres:5432/openai_gateway
