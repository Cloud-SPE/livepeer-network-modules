# Capability Broker — per-data-center worker entry point.
#
# Copy to .env, fill in your own values, then bring the stack up with:
#   docker compose \
#     -f infra/scenarios/orchestrator-onboarding/capability-broker/docker-compose.yml \
#     --env-file infra/scenarios/orchestrator-onboarding/capability-broker/.env \
#     up -d

# --- images ---
REGISTRY=tztcloud
TAG=v1.0.0
PAYMENT_TAG=v1.0.0

# --- chain wiring ---
# Single RPC endpoint used by the payment-daemon for ticket redemption.
CHAIN_RPC=https://arb1.arbitrum.io/rpc

# Your orchestrator's on-chain address (the cold orch identity, same value
# you set on the Secure Orch host). This is the address tickets are redeemed
# on behalf of — NOT the address that signs the redemption transaction.
ORCH_ADDRESS=0xYOUR_ORCH_ADDRESS

# --- payment-daemon hot wallet ---
# This is the keystore the payment-daemon uses to SIGN ticket-redemption
# transactions. It is the hot wallet for this broker box. It must:
#   - hold enough ETH to pay redemption gas
#   - have redeem authority on behalf of ORCH_ADDRESS
#
# This is a DIFFERENT key from the cold orch keystore on your Secure Orch
# host. Never copy the cold key here.
PAYMENT_KEYSTORE=/opt/livepeer/payment-keystore.json
PAYMENT_KEYSTORE_PASSWORD_FILE=/opt/livepeer/payment-keystore-password

# Optional: keystore password as env var instead of a file. Leave blank to
# use the file at PAYMENT_KEYSTORE_PASSWORD_FILE.
LIVEPEER_KEYSTORE_PASSWORD=

# --- gas / redemption tuning ---
GAS_PRICE_MULT_PCT=200
REDEEM_GAS=500000

# --- capability-broker config ---
# Host path to the host-config.yaml that defines which capabilities this
# broker advertises. Variants for common hardware mixes are documented
# separately.
BROKER_CONFIG=/opt/livepeer/host-config.yaml

# --- broker listeners ---
# Public broker endpoint — must be reachable by gateways. Put TLS in front.
BROKER_PUBLIC_BIND=0.0.0.0
BROKER_LISTEN_PORT=8080

# Metrics — keep private.
BROKER_METRICS_BIND=127.0.0.1
BROKER_METRICS_PORT=9090

# --- runtime ---
BROKER_LOG_LEVEL=info

# --- Ingress overlays — public hostname (Traefik / Nginx overlays) ---
# Public hostname for this broker. The ingress proxy issues a cert for it.
# MUST match the base_url you listed for this broker in your Orch
# Coordinator's coordinator-config.yaml (without the scheme prefix).
# Cloudflare Tunnel does not use this — the hostname lives in the Zero
# Trust UI for that ingress option.
BROKER_HOST=broker-a.example.com

# --- Traefik overlay (only used with docker-compose.traefik.yml) ---
# Which Traefik cert resolver to use. Match what's defined in your
# traefik.yml (default in the example: `cloudflare`; `letsencrypt` if you
# switched to HTTP-01).
TRAEFIK_CERTRESOLVER=cloudflare

# --- Nginx DNS-01 overlay (only used with docker-compose.nginx-dns01.yml) ---
# Leave blank when using HTTP-01 (docker-compose.nginx.yml) or any of the
# other ingress overlays. Populate to issue certs via Cloudflare DNS-01.
# Token must have Zone:DNS:Edit on the zone hosting BROKER_HOST.
CF_DNS_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
