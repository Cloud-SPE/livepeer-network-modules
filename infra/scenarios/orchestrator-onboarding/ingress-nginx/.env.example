# Nginx ingress — env file.
#
# Copy to .env, fill in your own values, then bring the stack up with:
#   docker network create ingress    # one-time, if not already created
#   docker compose \
#     -f infra/scenarios/orchestrator-onboarding/ingress-nginx/docker-compose.yml \
#     --env-file infra/scenarios/orchestrator-onboarding/ingress-nginx/.env \
#     up -d

# --- images ---
NGINX_PROXY_TAG=latest
ACME_COMPANION_TAG=latest

# --- ports ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- ACME ---
# Email Let's Encrypt sends expiry notices to. Required.
ACME_EMAIL=
