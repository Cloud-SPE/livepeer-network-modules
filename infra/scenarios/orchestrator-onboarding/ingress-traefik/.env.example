# Traefik ingress — env file.
#
# Copy to .env, fill in your own values, then bring the stack up with:
#   docker network create ingress  # one-time, if not already created
#   docker compose \
#     -f infra/scenarios/orchestrator-onboarding/ingress-traefik/docker-compose.yml \
#     --env-file infra/scenarios/orchestrator-onboarding/ingress-traefik/.env \
#     up -d

# --- image ---
TRAEFIK_TAG=v3.6.4

# --- ports ---
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443

# --- Cloudflare DNS challenge credentials (default cert resolver) ---
# Preferred: scoped DNS API token. Create at
# https://dash.cloudflare.com/profile/api-tokens with the "Edit zone DNS"
# template, scoped to the zone(s) that host your orchestrator domains.
CF_DNS_API_TOKEN=

# Legacy fallback: global API key + email. Use ONLY if you cannot create a
# scoped token. Leave blank when CF_DNS_API_TOKEN is set.
CF_API_EMAIL=
CF_API_KEY=

# --- on-disk paths ---
# Bind-mounted into the container at /etc/traefik. Drop your traefik.yml
# (and any dynamic config files) here.
TRAEFIK_CONFIG_DIR=/opt/livepeer/traefik
