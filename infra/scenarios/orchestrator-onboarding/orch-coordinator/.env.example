# Orch Coordinator — public-facing registry host.
#
# Copy to .env, fill in your own values, then bring the stack up with:
#   docker compose \
#     -f infra/scenarios/orchestrator-onboarding/orch-coordinator/docker-compose.yml \
#     --env-file infra/scenarios/orchestrator-onboarding/orch-coordinator/.env \
#     up -d

# --- image ---
REGISTRY=tztcloud
TAG=v1.0.0

# --- config file ---
# Host path to your coordinator config. This file defines your fleet:
# capability brokers, manifest identity, publish settings, etc.
# Bootstrap by copying coordinator-config.example.yaml to this path.
COORDINATOR_CONFIG=/opt/livepeer/coordinator-config.yaml

# --- admin auth ---
# Generate with: openssl rand -hex 32
# Used by the operator to push signed manifests / mutate fleet state.
# Treat as a secret. Comma-separate to support multiple tokens.
ORCH_COORDINATOR_ADMIN_TOKENS=

# --- listeners / port bindings ---
# Public registry endpoint — must be reachable by gateways.
COORDINATOR_PUBLIC_BIND=0.0.0.0
COORDINATOR_PUBLIC_PORT=8081

# Admin API — keep private (loopback + SSH tunnel, or behind your VPN).
COORDINATOR_ADMIN_BIND=127.0.0.1
COORDINATOR_LISTEN_PORT=8080

# Prometheus metrics — keep private.
COORDINATOR_METRICS_BIND=127.0.0.1
COORDINATOR_METRICS_PORT=9091

# --- runtime ---
COORDINATOR_LOG_LEVEL=info
COORDINATOR_LOG_FORMAT=text
COORDINATOR_SCRAPE_INTERVAL=5m

# --- Ingress overlays — public hostname (Traefik / Nginx overlays) ---
# Public hostname for this coordinator. The ingress proxy issues a cert
# for it. This is the URL you publish on the AI Service Registry contract.
# Cloudflare Tunnel does not use this — the hostname lives in the Zero
# Trust UI for that ingress option.
COORDINATOR_HOST=coordinator.example.com

# --- Traefik overlay (only used with docker-compose.traefik.yml) ---
# Which Traefik cert resolver to use. Match what's defined in your
# traefik.yml (default in the example: `cloudflare`; `letsencrypt` if you
# switched to HTTP-01).
TRAEFIK_CERTRESOLVER=cloudflare

# --- Nginx DNS-01 overlay (only used with docker-compose.nginx-dns01.yml) ---
# Leave blank when using HTTP-01 (docker-compose.nginx.yml) or any of the
# other ingress overlays. Populate to issue certs via Cloudflare DNS-01.
# Token must have Zone:DNS:Edit on the zone hosting COORDINATOR_HOST.
CF_DNS_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
