# Secure Orch — cold-key host.
#
# Copy to .env, fill in your own values, then bring the stack up with:
#   docker compose \
#     -f infra/scenarios/orchestrator-onboarding/secure-orch-control-plane/docker-compose.yml \
#     --env-file infra/scenarios/orchestrator-onboarding/secure-orch-control-plane/.env \
#     up -d

# --- images ---
REGISTRY=tztcloud
TAG=v1.0.0

# --- chain wiring ---
# ETH_URLS may be a comma-separated list; the daemon round-robins.
ETH_URLS=https://arb1.arbitrum.io/rpc,https://arbitrum.publicnode.com
CHAIN_RPC=https://arb1.arbitrum.io/rpc
CHAIN_ID=42161
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4
AI_SERVICE_REGISTRY_ADDRESS=0x04C0b249740175999E5BF5c9ac1dA92431EF34C5
SERVICE_REGISTRY_ADDRESS=
DISCOVERY_MODE=chain

# Your orchestrator's on-chain address. The keystore at PROTOCOL_KEYSTORE
# must hold the private key for this address.
ORCH_ADDRESS=0xYOUR_ORCH_ADDRESS

# --- protocol-daemon ---
PROTOCOL_MODE=both
MIN_BALANCE_WEI=5000000000000000
PROTOCOL_METRICS_PORT=9094

# Host paths to the cold keystore + password file. Convention: /opt/livepeer/
PROTOCOL_KEYSTORE=/opt/livepeer/keystore.json
PROTOCOL_KEYSTORE_PASSWORD_FILE=/opt/livepeer/keystore-password

# --- service-registry-daemon ---
REGISTRY_METRICS_PORT=9095

# --- secure-orch-console ---
# The console exposes a control plane API used by the operator to sign
# manifests with the cold key. Binding to 0.0.0.0 is acceptable ONLY on a
# host with no inbound internet (firewalled / private LAN). Otherwise bind
# to 127.0.0.1 and reach it over SSH tunnel.
SECURE_ORCH_LISTEN=0.0.0.0:8081
SECURE_ORCH_PORT=8081

# Generate with: openssl rand -hex 32
# Treat as a secret. Rotate on operator handoff.
SECURE_ORCH_ADMIN_TOKENS=

# Re-uses the same keystore + password as protocol-daemon by default. Override
# only if your secure-orch console signs with a different key.
SECURE_ORCH_KEYSTORE=/opt/livepeer/keystore.json
SECURE_ORCH_PASSWORD_FILE=/opt/livepeer/keystore-password
