REGISTRY=tztcloud
TAG=v1.0.0

VIDEO_GATEWAY_PORT=3000
VIDEO_RTMP_PORT=1935
GATEWAY_LOG_LEVEL=info

CHAIN_RPC=https://arb1.arbitrum.io/rpc
CHAIN_ID=42161
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4
SERVICE_REGISTRY_ADDRESS=0xYOUR_ONCHAIN_SERVICE_REGISTRY
DISCOVERY_MODE=chain
ROUND_POLL_INTERVAL=15s
CACHE_MANIFEST_TTL=5m
MANIFEST_MAX_BYTES=1048576
MANIFEST_FETCH_TIMEOUT=5s
MAX_STALE=30m
REJECT_UNSIGNED=true
STATIC_OVERLAY=
REGISTRY_LOG_LEVEL=info
REGISTRY_LOG_FORMAT=json
REGISTRY_METRICS_PORT=9095

LIVEPEER_RESOLVER_SNAPSHOT_TTL_MS=15000
BROKER_CALL_TIMEOUT_MS=30000
# Needed only for live RTMP proxying; VOD-only deployments can leave a placeholder.
LIVEPEER_BROKER_RTMP_HOST=broker.example.com
VIDEO_LIVE_RTMP_LISTEN_ADDR=:1935
VIDEO_LIVE_HLS_BASE_URL=https://playback.example.com/_hls
VIDEO_VOD_TUS_PATH=/v1/uploads
VIDEO_WEBHOOK_HMAC_PEPPER=change-me-before-production
VIDEO_GATEWAY_ABR_POLICY=customer-tier

PAYMENT_KEYSTORE=./run/gateway-hot-wallet-keystore.json
PAYMENT_KEYSTORE_PASSWORD_FILE=./run/keystore-password
LIVEPEER_KEYSTORE_PASSWORD=

POSTGRES_USER=livepeer
POSTGRES_PASSWORD=livepeer
POSTGRES_DB=video_gateway
POSTGRES_PORT=5432
DATABASE_URL=postgres://livepeer:livepeer@postgres:5432/video_gateway

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=rustfsadmin
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
S3_REGION=us-east-1
S3_BUCKET=transcoded
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin
S3_ENDPOINT=http://rustfs:9000
S3_FORCE_PATH_STYLE=true

CUSTOMER_PORTAL_PEPPER=change-me-before-production
# Optional unless you need /admin/* in this scenario.
VIDEO_GATEWAY_ADMIN_TOKENS=change-me-before-production
