REGISTRY=tztcloud
TAG=v1.0.0

OPENAI_GATEWAY_PORT=3000

# Set one routing mode:
#   - static broker: LIVEPEER_BROKER_URL=http://capability-broker:8080
#   - manifest-driven: LIVEPEER_RESOLVER_SOCKET=/var/run/livepeer/service-registry.sock
LIVEPEER_BROKER_URL=
LIVEPEER_RESOLVER_SOCKET=/var/run/livepeer/service-registry.sock
LIVEPEER_RESOLVER_SNAPSHOT_TTL_MS=15000

LIVEPEER_PAYER_DAEMON_SOCKET=/var/run/livepeer/payer-daemon.sock
LIVEPEER_DEFAULT_OFFERING=model-small

DATABASE_URL=postgres://livepeer:livepeer@postgres:5432/openai_gateway
OPENAI_AUDIO_SPEECH_ENABLED=false
BROKER_CALL_TIMEOUT_MS=30000
LOG_LEVEL=info

PAYMENT_DAEMON_SOCKET_DIR=/var/run/livepeer
