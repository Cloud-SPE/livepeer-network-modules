{
  "name": "@livepeer-rewrite/openai-gateway",
  "version": "0.2.0",
  "description": "OpenAI-compatible gateway for the Livepeer network rewrite (paid HTTP adapter)",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "files": ["dist", "README.md", "DESIGN.md"],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "start": "node ./dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test ./dist-test/test/**/*.test.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.2",
    "@grpc/proto-loader": "^0.7.13",
    "@fastify/websocket": "^11.2.0",
    "@livepeer-rewrite/customer-portal": "workspace:*",
    "@tztcloud/livepeer-gateway-middleware": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "js-yaml": "^4.1.0",
    "pg": "^8.13.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
