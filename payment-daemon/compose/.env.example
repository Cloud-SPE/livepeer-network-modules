REGISTRY=tztcloud
TAG=v1.0.0

CHAIN_RPC=https://arb1.arbitrum.io/rpc

# Receiver-side hot wallet / sender-side payer wallet.
PAYMENT_KEYSTORE=./run/keystore.json
PAYMENT_KEYSTORE_PASSWORD_FILE=./run/keystore-password
LIVEPEER_KEYSTORE_PASSWORD=

PAYMENT_DAEMON_SOCKET_DIR=/var/run/livepeer

GAS_PRICE_MULT_PCT=200
REDEEM_GAS=500000
