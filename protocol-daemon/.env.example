# Copy to .env and edit before `docker compose up`. Compose reads .env
# automatically for variable interpolation in compose.yaml.

# --- Image ---
# Pinned image tag. Bump on upgrade; published tags are listed at
# https://hub.docker.com/r/tztcloud/livepeer-protocol-daemon/tags
PROTOCOL_IMAGE_TAG=v3.0.1

# --- Mode ---
# round-init | reward | both. mode=both calls initializeRound AND
# rewardWithHint each round. mode=reward leaves the round-init job to
# someone else.
PROTOCOL_MODE=both

# --- Required ---

# Comma-separated Ethereum JSON-RPC URLs. Index 0 is primary; the rest
# are backups. Multi-RPC failover rotates on transient errors and
# rate-limits — recommend at least two endpoints for prod.
ETH_URLS=https://arb1.arbitrum.io/rpc,https://arbitrum.publicnode.com

# Expected chain ID. The daemon refuses to boot if the RPC reports a
# different one. 42161 = Arbitrum One.
CHAIN_ID=42161

# Livepeer Controller contract address. Default below is Arbitrum One;
# override only for forks / testnets.
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4

# Orchestrator on-chain address (cold transcoder identity registered
# with BondingManager). Required for reward + both modes.
ORCH_ADDRESS=0x0000000000000000000000000000000000000000

# --- Wallet preflight ---
# Refuse to start when the keystore wallet's balance is below this many
# wei. Default 5e15 ≈ 0.005 ETH (~50 reward calls of headroom).
MIN_BALANCE_WEI=5000000000000000

# --- Optional tuning (uncomment to use) ---

# Random delay before initializeRound. Useful only when running multiple
# protocol-daemons that might race for the round-init slot. Single
# orchestrator: leave 0.
# INIT_JITTER=0s

# Gas limit for round-init / reward txs.
# GAS_LIMIT=1000000

# --- Logging ---
LOG_FORMAT=json     # json | text
LOG_LEVEL=info      # debug | info | warn | error

# --- Observability ---
# Prometheus /metrics port. Empty = OFF (no listener bound; Recorder is
# a no-op). The daemon's recommended port is 9094 per
# docs/conventions/ports.md (livepeer-modules-project monorepo).
# To expose to the host, uncomment the `ports:` block in
# compose.yaml as well.
METRICS_PORT=9094
