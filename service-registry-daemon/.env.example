# Copy to .env and edit before `docker compose up`. Compose reads .env
# automatically for variable interpolation in compose.yaml.

# --- Image ---
# Pinned image tag. Bump on upgrade; published tags are listed at
# https://hub.docker.com/r/tztcloud/livepeer-service-registry-daemon/tags
REGISTRY_IMAGE_TAG=v1.0.0

# --- Required ---

# Ethereum JSON-RPC endpoint. Arbitrum One default below; override to
# point at your own RPC provider (Alchemy / Infura / dedicated node) for
# production. Public endpoints are fine for trying it out, rate-limited
# under load.
CHAIN_RPC=https://arb1.arbitrum.io/rpc

# Expected chain ID. The daemon refuses to boot if the RPC reports a
# different one. 42161 = Arbitrum One.
CHAIN_ID=42161

# Livepeer Controller contract address. Used to resolve BondingManager +
# RoundsManager + ServiceRegistry for resolver chain discovery. Default
# Arbitrum One.

# CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4

# --- Resolver auto-discovery ---
# Cache seeding source. "chain" walks the BondingManager active pool
# on each round event (default; ~2N+1 RPC calls per ~19 hours on
# Arbitrum One). "overlay-only" disables auto-discovery; cache fed only
# by --static-overlay + per-address gRPC calls. Pick "overlay-only" for
# strict-allowlist gateways.

# DISCOVERY=chain

# How often the chain-commons timesource polls
# RoundsManager.currentRound() to detect round transitions. Bounds
# detection latency for round-boundary cache refreshes. Default 1 minute
# (plenty given ~19h rounds).

# ROUND_POLL_INTERVAL=1m

# --- Publisher options (uncomment to enable) ---

# ORCH_ADDRESS — cold orchestrator identity if it differs from the
# keystore signing address. Leave unset to use the keystore address.
# ORCH_ADDRESS=0xYourColdOrchAddress

# ALLOW_ON_CHAIN_WRITES — explicit gate on the WriteServiceURI gRPC
# method (which spends gas to publish the manifest URL on-chain). Off
# by default. Uncomment + set to true when ready.
# ALLOW_ON_CHAIN_WRITES=true

# --- Logging ---
LOG_FORMAT=json     # json | text
LOG_LEVEL=info      # debug | info | warn | error

# --- Observability ---
# Prometheus /metrics port. Empty = OFF (no listener bound; Recorder is
# a no-op). The daemon's recommended port is 9091 per
# docs/conventions/ports.md (livepeer-modules-project monorepo).
# To expose to the host, uncomment the `ports:` block in
# compose.yaml as well.
METRICS_PORT=9091
