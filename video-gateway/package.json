{
  "name": "@livepeer-network-modules/video-gateway",
  "version": "0.1.0",
  "description": "Video product gateway (live streams + VOD) for the Livepeer network rewrite",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "migrations",
    "README.md",
    "src/frontend/admin/dist",
    "src/frontend/portal/dist"
  ],
  "scripts": {
    "build": "pnpm -F @livepeer-network-modules/customer-portal-shared build && tsc && vite build --config vite.portal.config.ts && vite build --config vite.admin.config.ts",
    "lint": "tsc --noEmit",
    "start": "node ./dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test ./dist-test/test/**/*.test.js"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@grpc/grpc-js": "^1.12.2",
    "@grpc/proto-loader": "^0.8.1",
    "@livepeer-network-modules/customer-portal": "workspace:*",
    "@livepeer-network-modules/customer-portal-shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.0",
    "lit": "^3.2.0",
    "node-media-server": "^4.0.5",
    "pg": "^8.13.0",
    "rxjs": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.11.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=20"
  }
}
