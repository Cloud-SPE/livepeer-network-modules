REGISTRY=tztcloud
TAG=v1.0.0

VTUBER_GATEWAY_PORT=3001
LOG_LEVEL=info

LIVEPEER_BROKER_URL=http://capability-broker:8080
LIVEPEER_RESOLVER_SOCKET=
LIVEPEER_RESOLVER_PROTO_ROOT=/app/proto-contracts
LIVEPEER_RESOLVER_SNAPSHOT_TTL_MS=15000
LIVEPEER_PAYER_DAEMON_SOCKET=/var/run/livepeer/payer-daemon.sock
PAYMENT_DAEMON_SOCKET_DIR=/var/run/livepeer
LIVEPEER_PAYMENT_PROTO_ROOT=/app/proto
LIVEPEER_PAYER_DEFAULT_FACE_VALUE_WEI=5000000000000000000
PROTO_ROOT=../../livepeer-network-protocol/proto
PROTO_CONTRACTS_ROOT=../../proto-contracts

VTUBER_DEFAULT_OFFERING=default
VTUBER_SESSION_BEARER_PEPPER=replace-with-long-random-string
VTUBER_WORKER_CONTROL_BEARER_PEPPER=replace-with-long-random-string
VTUBER_SESSION_DEFAULT_TTL_SECONDS=3600
VTUBER_SESSION_BEARER_TTL_SECONDS=7200
VTUBER_RATE_CARD_USD_PER_SECOND=0.01
VTUBER_WORKER_CALL_TIMEOUT_MS=15000
VTUBER_RELAY_MAX_PER_SESSION=8
VTUBER_CONTROL_RECONNECT_WINDOW=30s
VTUBER_CONTROL_RECONNECT_BUFFER_MESSAGES=64
VTUBER_CONTROL_RECONNECT_BUFFER_BYTES=1048576

DATABASE_URL=postgres://livepeer:livepeer@postgres:5432/vtuber_gateway
CUSTOMER_PORTAL_PEPPER=replace-with-long-random-string
