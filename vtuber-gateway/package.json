    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "stripe": "^14.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
